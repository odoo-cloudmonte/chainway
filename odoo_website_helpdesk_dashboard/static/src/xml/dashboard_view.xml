<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- =========================================================
                            MAIN DASHBOARD
    ========================================================== -->

    <t t-name="HelpDesk_Dashboard" owl="1">

        <div class="helpdesk_dashboards">
            <div class="container-fluid helpdesk_dashboard_main"/>
        </div>

    </t>

    <!-- =========================================================
                            DASHBOARD TEMPLATE
    ========================================================== -->

    <t t-name="DashBoardHelpDesk">

        <!-- =========================================================
                                INLINE CSS
        ========================================================== -->

        <style>

            .modern_helpdesk_dashboard{
                background:#f4f7fb;
                min-height:100vh;
                padding:25px;
                font-family:'Segoe UI',sans-serif;
            }

            /* =====================================================
                                HEADER
            ====================================================== */

            .dashboard-header{
                display:flex;
                justify-content:space-between;
                align-items:center;
                margin-bottom:30px;
            }

            .dashboard-title{
                font-size:34px;
                font-weight:700;
                color:#1e293b;
                margin-bottom:5px;
            }

            .dashboard-subtitle{
                color:#64748b;
                font-size:15px;
            }

            .dashboard-live{
                background:white;
                padding:12px 20px;
                border-radius:12px;
                box-shadow:0 5px 15px rgba(0,0,0,0.06);
                font-weight:600;
                color:#334155;
            }

            /* =====================================================
                                TOP CARDS
            ====================================================== */

            .modern-card{
                background:white;
                border-radius:18px;
                padding:24px;
                display:flex;
                align-items:center;
                gap:18px;
                box-shadow:0 5px 18px rgba(0,0,0,0.06);
                transition:0.3s ease;
                cursor:pointer;
                height:100%;
            }

            .modern-card:hover{
                transform:translateY(-5px);
            }

            .card-icon{
                width:68px;
                height:68px;
                border-radius:18px;
                display:flex;
                justify-content:center;
                align-items:center;
                color:white;
                font-size:28px;
            }

            .card-info h5{
                margin:0;
                color:#64748b;
                font-size:14px;
                font-weight:600;
            }

            .card-info h2{
                margin-top:8px;
                font-size:32px;
                font-weight:700;
                color:#0f172a;
            }

            /* =====================================================
                                CARD COLORS
            ====================================================== */

            .new-card .card-icon{
                background:linear-gradient(135deg,#ec4899,#f472b6);
            }

            .progress-card .card-icon{
                background:linear-gradient(135deg,#f59e0b,#fbbf24);
            }

            .device-card .card-icon{
                background:linear-gradient(135deg,#8b5cf6,#a78bfa);
            }

            .engineer-card .card-icon{
                background:linear-gradient(135deg,#3b82f6,#60a5fa);
            }

            .approval-card .card-icon{
                background:linear-gradient(135deg,#6366f1,#818cf8);
            }

            .dispatch-card .card-icon{
                background:linear-gradient(135deg,#14b8a6,#2dd4bf);
            }

            .cancel-card .card-icon{
                background:linear-gradient(135deg,#ef4444,#f87171);
            }

            .done-card .card-icon{
                background:linear-gradient(135deg,#10b981,#34d399);
            }

            .closed-card .card-icon{
                background:linear-gradient(135deg,#334155,#64748b);
            }

            /* =====================================================
                        CUSTOMER SATISFACTION
            ====================================================== */

            .satisfaction-card{
                margin-top:35px;
                background:linear-gradient(135deg,#4f46e5,#7c3aed);
                padding:30px;
                border-radius:22px;
                color:white;
                display:flex;
                justify-content:space-between;
                align-items:center;
                box-shadow:0 10px 20px rgba(79,70,229,0.2);
            }

            .satisfaction-left h4{
                font-size:26px;
                font-weight:700;
            }

            .satisfaction-left p{
                margin-top:5px;
                opacity:0.9;
            }

            .satisfaction-right{
                display:flex;
                align-items:center;
                gap:20px;
            }

            .emoji{
                font-size:48px;
            }

            .response-title{
                display:block;
                font-weight:600;
                margin-bottom:5px;
            }

            .response{
                font-size:24px;
                font-weight:700;
            }

            /* =====================================================
                                CHARTS
            ====================================================== */

            .chart-card{
                background:white;
                border-radius:18px;
                padding:25px;
                box-shadow:0 5px 18px rgba(0,0,0,0.06);
                height:100%;
            }

            .chart-header h4{
                font-size:22px;
                font-weight:700;
                margin-bottom:20px;
                color:#0f172a;
            }

            .graph_canvas{
                display:flex;
                justify-content:center;
                align-items:center;
            }

            /* =====================================================
                            PRIORITY SECTION
            ====================================================== */

            .priority-item{
                margin-bottom:18px;
            }

            .priority-item label{
                display:block;
                margin-bottom:8px;
                font-weight:600;
                color:#334155;
            }

            .modern-progress{
                background:#e5e7eb;
                border-radius:20px;
                overflow:hidden;
                height:12px;
            }

            .progress-value{
                height:100%;
                width:65%;
                border-radius:20px;
                background:linear-gradient(90deg,#6366f1,#8b5cf6);
            }

            /* =====================================================
                                RESPONSIVE
            ====================================================== */

            @media(max-width:768px){

                .dashboard-header{
                    flex-direction:column;
                    align-items:flex-start;
                    gap:15px;
                }

                .satisfaction-card{
                    flex-direction:column;
                    text-align:center;
                    gap:20px;
                }
            }

        </style>

        <!-- =========================================================
                                DASHBOARD BODY
        ========================================================== -->

        <div class="container-fluid helpdesk_dashboard_main modern_helpdesk_dashboard"
             t-ref="helpDeskDashboard">

            <!-- =====================================================
                                HEADER
            ====================================================== -->

            <div class="dashboard-header">

                <div>

                    <h1 class="dashboard-title">
                        HelpDesk Dashboard
                    </h1>

                    <p class="dashboard-subtitle">
                        Monitor tickets, engineers, dispatch, approvals and workflow.
                    </p>

                </div>

                <div class="dashboard-live">

                    <i class="fa fa-calendar"/>

                    Live Dashboard

                </div>

            </div>

            <!-- =====================================================
                                STAGE CARDS
            ====================================================== -->

            <div class="row g-4">

                <!-- NEW -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_new">

                    <div class="modern-card new-card">

                        <div class="card-icon">
                            <i class="fa fa-ticket"/>
                        </div>

                        <div class="card-info">
                            <h5>New</h5>
                            <h2 id="new_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- IN PROGRESS -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_inprogress">

                    <div class="modern-card progress-card">

                        <div class="card-icon">
                            <i class="fa fa-spinner"/>
                        </div>

                        <div class="card-info">
                            <h5>In Progress</h5>
                            <h2 id="inprogress_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- DEVICE RECEIVED -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_device_received">

                    <div class="modern-card device-card">

                        <div class="card-icon">
                            <i class="fa fa-laptop"/>
                        </div>

                        <div class="card-info">
                            <h5>Device Received</h5>
                            <h2 id="device_received_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- ASSIGN ENGINEER -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_assign_engineer">

                    <div class="modern-card engineer-card">

                        <div class="card-icon">
                            <i class="fa fa-user"/>
                        </div>

                        <div class="card-info">
                            <h5>Assign to Engineer</h5>
                            <h2 id="assign_engineer_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- PENDING APPROVAL -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_pending_approval">

                    <div class="modern-card approval-card">

                        <div class="card-icon">
                            <i class="fa fa-clock-o"/>
                        </div>

                        <div class="card-info">
                            <h5>Pending Approval</h5>
                            <h2 id="pending_approval_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- DISPATCH -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_dispatch">

                    <div class="modern-card dispatch-card">

                        <div class="card-icon">
                            <i class="fa fa-truck"/>
                        </div>

                        <div class="card-info">
                            <h5>Dispatch</h5>
                            <h2 id="dispatch_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- CANCELLED -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_cancelled">

                    <div class="modern-card cancel-card">

                        <div class="card-icon">
                            <i class="fa fa-times-circle"/>
                        </div>

                        <div class="card-info">
                            <h5>Cancelled</h5>
                            <h2 id="cancelled_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- DONE -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_done">

                    <div class="modern-card done-card">

                        <div class="card-icon">
                            <i class="fa fa-check-circle"/>
                        </div>

                        <div class="card-info">
                            <h5>Done</h5>
                            <h2 id="done_count">0</h2>
                        </div>

                    </div>

                </div>

                <!-- CLOSED -->

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12"
                     t-on-click="tickets_closed">

                    <div class="modern-card closed-card">

                        <div class="card-icon">
                            <i class="fa fa-lock"/>
                        </div>

                        <div class="card-info">
                            <h5>Closed</h5>
                            <h2 id="closed_count">0</h2>
                        </div>

                    </div>

                </div>

            </div>

