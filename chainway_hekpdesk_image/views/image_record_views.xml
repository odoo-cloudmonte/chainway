<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_image_record_tree" model="ir.ui.view">
        <field name="name">image.record.tree</field>
        <field name="model">image.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="image_url"/>
            </list>
        </field>
    </record>

    <record id="view_image_record_form" model="ir.ui.view">
        <field name="name">image.record.form</field>
        <field name="model">image.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="image" widget="image"/>
                        <field name="image_url" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_image_record" model="ir.actions.act_window">
        <field name="name">Images</field>
        <field name="res_model">image.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_image_root" name="Image Module"/>
    <menuitem id="menu_image_record" name="Images"
              parent="menu_image_root"
              action="action_image_record"/>
</odoo>