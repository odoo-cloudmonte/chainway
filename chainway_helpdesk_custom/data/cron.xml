<odoo>
    <record id="ir_cron_ticket_overdue_check" model="ir.cron">
        <field name="name">Ticket Overdue Check</field>
        <field name="model_id" ref="model_ticket_helpdesk"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_ticket_states()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="device_inventory_mis" model="res.groups">
        <field name="name">MIS</field>
    </record>

    <record id="action_export_sr_server" model="ir.actions.server">
        <field name="name">Export SR</field>
        <field name="model_id" ref="chainway_helpdesk_custom.model_ticket_helpdesk"/>
        <field name="binding_model_id" ref="chainway_helpdesk_custom.model_ticket_helpdesk"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
    action = records.action_export_sr()
        </field>
    </record>
