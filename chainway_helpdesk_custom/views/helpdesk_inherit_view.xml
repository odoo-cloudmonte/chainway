<odoo>

    <record id="view_ticket_helpdesk_form_inherit_devices" model="ir.ui.view">
        <field name="name">ticket.helpdesk.form.inherit.devices</field>
        <field name="model">ticket.helpdesk</field>
        <field name="inherit_id" ref="odoo_website_helpdesk.ticket_helpdesk_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_export_sr"
                        type="object"
                        string="Export SR"
                        class="oe_highlight"/>
                <button name="action_import_sr"
                        type="object"
                        string="Import SR"
                        class="btn-primary"/>
            </xpath>
            <xpath expr="//field[@name='description']/ancestor::page" position="after">
                <page string="Devices">
                    <field name="sr_ids">
                        <list editable="bottom">
                            <field name="sequence" readonly="1"/>
                            <field name="device_sn"/>
                            <field name="model_mo"/>
                            <field name="device_condition"/>        
                            <field name="description"/>
                            <field name="remark"/>
                        </list>
                    </field>
                </page>
                <page string="Company Details">
                    <group>
                        <group>
                            <field name="company_name"/>
                            <field name="company_address"/>
                            <field name="store"/>
                            
                        </group>
                        <group>
                            <field name="contact"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>

                    </group>
                    
                    
                </page>

            </xpath>
            <!-- <xpath expr="//notebook" position="inside">

                <page string="Company Details">
                    <group>
                        <group>
                            <field name="company_name"/>
                            <field name="company_address"/>
                        </group>
                        <group>
                            <field name="contact"/>
                            <field name="store"/>
                        </group>

                    </group>
                    
                    
                </page>

            </xpath> -->

        </field>
    </record>

    <record id="ticket_helpdesk_view_list_inherit_color" model="ir.ui.view">
    <field name="name">ticket.helpdesk.view.list.inherit.color</field>
    <field name="model">ticket.helpdesk</field>
    <field name="inherit_id" ref="odoo_website_helpdesk.ticket_helpdesk_view_list"/>
    <field name="arch" type="xml">

        <!-- Add fields (required for decoration) -->
        <xpath expr="//list" position="inside">
            <field name="sr_device_sn" optional="True"/>
            <field name="sr_device_model" optional="True"/>
            <!-- <field name="is_overdue" optional="True"/>
            <field name="is_closed" optional="True"/>
            <field name="is_on_time" optional="True"/>
            <field name="is_super_overdue" optional="True"/> -->
        </xpath>

        <!-- Apply colors -->
        <xpath expr="//list" position="attributes">
            <!-- 🔴 Overdue -->
            <attribute name="decoration-warning">is_overdue</attribute>
            <attribute name="decoration-danger">is_super_overdue</attribute>

            <!-- 🟢 Completed -->
            <attribute name="decoration-success">is_closed</attribute>

            <!-- 🟡 On time -->
            <attribute name="decoration-info">is_on_time</attribute>
        </xpath>

    </field>
</record>

    
    <template id="hide_passkey_login_css" inherit_id="web.login_layout">
        <xpath expr="." position="inside">
            <style>
                .passkey_login_link {
                    display: none !important;
                }
                .o_login_auth{
                    display: none !important;
                }
            </style>
        </xpath>
    </template>

    <record id="view_helpdesk_sr_import_wizard" model="ir.ui.view">
        <field name="name">helpdesk.sr.import.wizard.form</field>
        <field name="model">helpdesk.sr.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Service Requests">

                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>

                <footer>
                    <a href="/chainway_helpdesk_custom/static/files/helpdesk_sr_import_format.xlsx"
                        class="btn btn-outline-info"
                        download="helpdesk_sr_import_format.xlsx">
                            <i class="fa fa-download"/>
                            Download Format
                        </a>
                    <button name="action_sr_import"
                            type="object"
                            string="Import"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

   
</odoo>