<odoo>
    <record id="view_users_form_inherit_device_ui" model="ir.ui.view">
        <field name="name">res.users.form.inherit.device.ui</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Access Control">
                    <group>
                        <field name="show_device_ui"/>
                        <!-- <field name="mis_access"/> -->
                        
                    <!-- <field name="group_ids" eval="[(4, ref('chainway_helpdesk_custom.device_inventory_mis'))]"/> -->
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <record id="res_config_settings_view_form_import_button" model="ir.ui.view">
        <field name="name">res.config.settings.import.button</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="chainway_helpdesk" string="Helpdesk" logo="/chainway_helpdesk_custom/static/description/helpdesk.png">
                    <block title="Portal Settings">
                        <setting string="Show Import Devices Button">
                            <field name="show_import_button"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    


    

</odoo>