<odoo>

    <!-- Tree View -->
    <record id="view_device_inventory_tree" model="ir.ui.view">
        <field name="name">device.inventory.tree</field>
        <field name="model">device.inventory</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    

                    <button name="action_open_import_wizard"
                            type="object"
                            string="Import"
                            class="btn-primary"
                            display="always"/>
                    <button name="action_download_template"
                            type="object"
                            string="Import Format"
                            class="btn-secondary"
                            display="always"/>
                </header>

                <field name="device_sn"/>
                <field name="type"/>
                <field name="imei1"/>
                <field name="model"/>
                <field name="end_user_name"/>
                <field name="pod_copy" widget="image" options="{'size': [80, 80]}"/>
                <field name="description" optional="true"/>
                <field name="chainway_reference" optional="true"/>
                <field name="remark" optional="true"/>
                <field name="imei2" optional="true"/>
                <field name="bt_mac" optional="true"/>
                <field name="wifi_mac" optional="true"/>
                <field name="sw_version" optional="true"/>
                <field name="delivery_date" optional="true"/>
                <field name="configuration_in" optional="true"/>
                <field name="configuration_out" optional="true"/>
                <field name="po_no" optional="true"/>
                <field name="po_date" optional="true"/>
                <field name="invoice_no" optional="true"/>
                <field name="invoice_date" optional="true"/>
                <field name="warranty_wef" optional="true"/>
                <field name="warranty_category" optional="true"/>
                <field name="warranty_upto" optional="true"/>
                <field name="location" optional="true"/>
                <field name="location_code" optional="true"/>
                <field name="delivery_location" optional="true"/>
                <field name="delivery_date" optional="true"/>
                <field name="shipping_address_po" optional="true"/>
                <field name="shipping_address_invoice" optional="true"/>
                <field name="courier_name" optional="true"/>
                <field name="tracking_id" optional="true"/>
            </list>
        </field>
    </record>                                      

    <!-- Form View -->
    <record id="view_device_inventory_form" model="ir.ui.view">
        <field name="name">device.inventory.form</field>
        <field name="model">device.inventory</field>
        <field name="arch" type="xml">
            <form string="Device Inventory">
                <sheet>
                    <group>
                        <group>
                            <field name="end_user_name"/>
                            <field name="device_sn"/>
                            <!-- accessories_sn removed -->
                            <field name="type"/>
                            <field name="model"/>
                            <field name="description"/>
                        </group>

                        <group>
                            <field name="imei1"/>
                            <field name="imei2"/>
                            <field name="bt_mac"/>
                            <field name="wifi_mac"/>
                            <field name="sw_version"/>
                            <!-- <field name="device_condition"/> -->
                        </group>

                        <!-- ✅ POD Image in main view -->
                        <group>
                            <field name="pod_copy" widget="image" class="oe_avatar"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Configuration">
                            <group>
                                <field name="configuration_in"/>
                                <field name="configuration_out"/>
                            </group>
                        </page>

                        <page string="Warranty">
                            <group>
                                <field name="warranty_wef"/>
                                <field name="warranty_category"/>
                                <field name="warranty_upto"/>
                            </group>
                        </page>

                        <page string="Purchase Info">
                            <group>
                                <field name="po_no"/>
                                <field name="po_date"/>
                                <field name="invoice_no"/>
                                <field name="invoice_date"/>
                            </group>
                        </page>

                        <page string="Delivery">
                            <group>
                                <field name="location"/>
                                <field name="location_code"/>
                                <field name="delivery_location"/>
                                <field name="delivery_date"/>
                            </group>
                        </page>

                        <page string="Shipping">
                            <group>
                                <field name="shipping_address_po"/>
                                <field name="shipping_address_invoice"/>
                                <field name="courier_name"/>
                                <field name="tracking_id"/>
                            </group>
                        </page>

                        <!-- ❌ Removed Attachments tab since image is now in main view -->

                        <page string="Other">
                            <group>
                                <field name="chainway_reference"/>
                                <field name="Chainway_pi_no"/>
                                <field name="remark"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>