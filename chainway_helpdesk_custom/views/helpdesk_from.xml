<odoo>
<template id="smart_form_template">
 
<div>
 
<style>
body {
    font-family: Arial;
    background: #f2f2f2;
}
 
/* CONTAINER */
.help-container {
    width: 96%;
    margin: 30px auto;
    background: #fff;
    padding: 25px;
}
 
/* GRID */
.help-row {
    display: grid;
    gap: 15px;
    margin-bottom: 15px;
}
 
.row-3 {
    grid-template-columns: repeat(3, 1fr);
}
 
.row-4 {
    grid-template-columns: repeat(4, 1fr);
}
 
.help-group {
    display: flex;
    flex-direction: column;
}
 
/* INPUT */
input, select, textarea {
    padding: 12px;
    margin-bottom: 5px;
    border: 1px solid #bfbfbf;
    background: #f9f9f9;
    border-radius: 6px;
}
 
/* MULTI */
.multi-wrapper {
    border: 1px solid #e0e0e0;
    padding: 12px;
    border-radius: 6px;
}
 
.multi-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 10px;
    align-items: center;
}
 
/* DELETE BUTTON */
.field-del {
    background: #ff5a1f;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
}
 
/* ADD BUTTON */
.add-btn {
    margin: 20px auto;
    padding: 14px;
    background: #3b2fa3;
    color: #fff;
    border: none;
    width: 30%;
    display: block;
    border-radius: 6px;
    cursor: pointer;
}
 
/* LAST ROW */
hr {
    border: 0;
    border-top: 1px dashed #ccc;
    margin: 20px 0;
}
 
/* LABEL */
label {
    font-size: 14px;
    margin-bottom: 5px;
}
 
label span {
    color: red;
}
 
/* SUBMIT BUTTON */
.send-container {
    display: flex;
    justify-content: center;
    padding: 30px 0;
}
 
.send-btn {
    font-size: 18px;
    background: linear-gradient(135deg, #5f8dee, #3b5ed7);
    color: #fff;
    padding: 14px 35px;
    display: flex;
    align-items: center;
    border: none;
    border-radius: 20px;
    cursor: pointer;
}
 
.send-text {
    margin-left: 10px;
}
 
/* MOBILE */
@media (max-width: 768px) {
    .help-row {
        grid-template-columns: 1fr !important;
    }
 
    .multi-row {
        grid-template-columns: 1fr;
    }
 
    .add-btn {
        width: 100%;
    }
}
</style>
 
<div class="help-container">
 
<!-- ROW 1 -->
<div class="help-row row-3">
    <div class="help-group">
        <label>Company Name <span>*</span></label>
        <input type="text" placeholder="Company Name" required="required"/>
    </div>
 
    <div class="help-group">
        <label>Customer Address <span>*</span></label>
        <input type="text" placeholder="Customer Address" required="required"/>
    </div>
 
    <div class="help-group">
        <label>City <span>*</span></label>
        <input type="text" placeholder="City" required="required"/>
    </div>
</div>
 
<!-- ROW 2 -->
<div class="help-row row-3">
    <div class="help-group">
        <label>Store Location <span>*</span></label>
        <input type="text" placeholder="Store Location"/>
    </div>
 
    <div class="help-group">
        <label>Contact Person <span>*</span></label>
        <input type="text" placeholder="Contact Person" required="required"/>
    </div>
 
    <div class="help-group">
        <label>Email <span>*</span></label>
        <input type="text" placeholder="Email" required="required"/>
    </div>
</div>
 
